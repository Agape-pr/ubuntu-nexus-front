# ============================================
# API Configuration
# ============================================

# Backend API Base URL
# Currently using Render production URL
VITE_API_BASE_URL=https://ubuntunow-now-be.onrender.com/api/v1

# ============================================
# Local Development (commented out)
# ============================================
# Uncomment the line below to use local backend during development:
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# ============================================
# Notes
# ============================================
# - The API uses /api/v1/ prefix for all endpoints
# - Make sure to comment/uncomment the appropriate URL based on your environment
# - Restart dev server after changing this file: npm run dev