# ============================================
# API Base URL (Frontend requests hit this path)
# ============================================
# Keep this as /api/v1 locally so the Vite proxy handles CORS.
# For Production deployments (e.g. Vercel), set VITE_API_BASE_URL directly to:
# https://api-gateway-production-a85d.up.railway.app/api/v1
VITE_API_BASE_URL=/api/v1

# ============================================
# Local Development Proxy Target
# ============================================
# Choose which backend you want to test against locally.
# The Vite proxy will forward local '/api/v1' requests to this target, bypassing CORS.
# Uncomment ONLY ONE of the options below:

# Option 1: Live Testing (Railway)
VITE_PROXY_TARGET=https://api-gateway-production-a85d.up.railway.app

# Option 2: Local Testing (Local Django)
# VITE_PROXY_TARGET=http://localhost:8000