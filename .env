# ============================================
# API Configuration
# ============================================

# Local Development (proxy avoids CORS - backend must be at localhost:8000)
# VITE_API_BASE_URL=/api/v1

# ============================================
# Production (Render) - uncomment when deploying
# ============================================
VITE_API_BASE_URL=https://ubuntunow-now-be.onrender.com/api/v1

# ============================================
# Notes
# ============================================
# - Local: Use /api/v1 - Vite proxies to localhost:8000 (no CORS)
# - Production: Set full Render URL in Vercel env vars
# - Restart dev server after changing: npm run dev