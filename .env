# ============================================
# API Base URL — direct Railway call (no proxy)
# ============================================
# Calling Railway directly avoids the Next.js proxy redirect loop.
NEXT_PUBLIC_API_BASE_URL=https://api-gatewayubuntunow-platform-be-production.up.railway.app/api/v1

# ============================================
# Local Development Proxy Target (unused when calling Railway directly)
# ============================================
# NEXT_PUBLIC_PROXY_TARGET=https://api-gatewayubuntunow-platform-be-production.up.railway.app/api

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=doozvruxr