# API Configuration
# Copy this file to .env and update with your actual API URL

# Local development (uses Vite proxy - no CORS, backend at localhost:8000)
VITE_API_BASE_URL=/api/v1

# Production (full URL - set in Vercel env vars for deployment)
# VITE_API_BASE_URL=https://api-gateway-production-a85d.up.railway.app/api/v1

# Note: For local dev, /api/v1 is proxied to localhost:8000 in vite.config.ts
