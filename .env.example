# API Configuration
# Copy this file to .env and update with your actual API URL

# Backend API Base URL (should include /api/v1)
# For local development, use: http://localhost:8000/api/v1
# For production, use your deployed API URL
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Example for different environments:
# Development: VITE_API_BASE_URL=http://localhost:8000/api/v1
# Staging: VITE_API_BASE_URL=https://api-staging.yourapp.com/api/v1
# Production: VITE_API_BASE_URL=https://api.yourapp.com/api/v1

# Note: The API uses /api/v1/ prefix for all endpoints
